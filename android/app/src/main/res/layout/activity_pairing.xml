<?xml version="1.0" encoding="utf-8"?>
<!--
  Pantalla de emparejamiento P2P — Material Design 3
  ViewFlipper con 3 hijos:
    0 = Home    (Crear / Unirse)
    1 = Hosting (QR display)
    2 = Joining (Cámara / manual)
-->
<ViewFlipper
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/viewFlipper"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- ══════════════════════════════════════════════════════════════════
         0 — HOME
         ══════════════════════════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="24dp"
            android:paddingTop="48dp"
            android:paddingBottom="40dp">

            <!-- Icono / logo -->
            <TextView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:text="📡"
                android:textSize="40sp"
                android:gravity="center"
                android:background="@drawable/circle_primary_container"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gravital Talk"
                android:textAppearance="?attr/textAppearanceHeadlineLarge"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Push-To-Talk cifrado, sin servidor obligatorio"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:gravity="center"
                android:layout_marginBottom="48dp" />

            <!-- Botón principal: Crear llamada -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCreateCall"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="@string/btn_create_call"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:layout_marginBottom="16dp"
                app:cornerRadius="30dp"
                app:iconGravity="textStart"
                app:iconPadding="12dp" />

            <!-- Botón secundario: Unirse -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnJoinCall"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="@string/btn_join_call"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:layout_marginBottom="40dp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="30dp"
                app:iconGravity="textStart"
                app:iconPadding="12dp" />

            <!-- Divisor -->
            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp" />

            <!-- Relay opcional (avanzado) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Opciones avanzadas"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_relay_optional"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRelayOptional"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:imeOptions="actionDone"
                    android:singleLine="true" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ══════════════════════════════════════════════════════════════════
         1 — HOST (mostrar QR)
         ══════════════════════════════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp">

        <!-- Título -->
        <TextView
            android:id="@+id/tvHostTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/share_code"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:textColor="?attr/colorOnSurface"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvHostSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="El otro dispositivo debe escanear este código"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvHostTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- QR container -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardQr"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="#FFFFFFFF"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/tvHostSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_max="320dp">

            <ImageView
                android:id="@+id/ivQrCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:padding="16dp"
                android:contentDescription="QR de emparejamiento" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Código de texto -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="?attr/colorPrimaryContainer"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/cardQr"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvTextCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="24dp"
                android:paddingVertical="10dp"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:fontFamily="monospace"
                android:letterSpacing="0.2" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Estado -->
        <LinearLayout
            android:id="@+id/layoutStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/cardCode"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:indeterminate="true"
                app:indicatorSize="20dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvStatusHost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pairing_waiting"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant" />

        </LinearLayout>

        <!-- Botón cancelar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelHost"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_cancel"
            style="@style/Widget.Material3.Button.TextButton"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ══════════════════════════════════════════════════════════════════
         2 — JOIN (escanear QR o ingresar manualmente)
         ══════════════════════════════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Tabs -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabHost"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:tabMode="fixed"
            app:tabGravity="fill"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_scan_qr"
                android:icon="@android:drawable/ic_menu_camera" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_enter_code"
                android:icon="@android:drawable/ic_menu_edit" />

        </com.google.android.material.tabs.TabLayout>

        <!-- Cámara QR -->
        <androidx.camera.view.PreviewView
            android:id="@+id/cameraPreview"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/tabHost"
            app:layout_constraintBottom_toTopOf="@id/btnBackToHome"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Overlay guía escaneo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Apunta la cámara al código QR"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="@color/white"
            android:background="#99000000"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            app:layout_constraintTop_toBottomOf="@id/tabHost"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.15" />

        <!-- Manual relay (oculto por defecto) -->
        <LinearLayout
            android:id="@+id/layoutManual"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tabHost"
            app:layout_constraintBottom_toTopOf="@id/btnBackToHome"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ingresa la dirección del relay"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="El host debe compartir la dirección del servidor relay."
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginBottom="20dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_relay_host_port"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etManualRelay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:imeOptions="actionDone"
                    android:singleLine="true"
                    android:hint="relay.ejemplo.com:9000" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnJoinManual"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Conectar"
                app:cornerRadius="28dp" />

        </LinearLayout>

        <!-- Botón volver -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackToHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:text="@string/btn_cancel"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ViewFlipper>
